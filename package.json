{
  "name": "connector-capability-matrix-skill",
  "version": "0.1.0",
  "description": "Dry-run connector action plans against declared capabilities and approvals.",
  "type": "module",
  "bin": {
    "connector-capability-matrix-skill": "bin/connector-capability-matrix-skill.js"
  },
  "exports": {
    ".": "./src/index.js"
  },
  "scripts": {
    "test": "node --test",
    "check": "node scripts/check.js",
    "build": "node scripts/build.js",
    "smoke": "node bin/connector-capability-matrix-skill.js --fixture fixtures/action-plan.json",
    "lint": "npm run check",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "agent-skill",
    "connector",
    "permissions",
    "dry-run"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/connector-capability-matrix-skill.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/connector-capability-matrix-skill/issues"
  },
  "homepage": "https://github.com/rogerchappel/connector-capability-matrix-skill#readme",
  "files": [
    "bin",
    "src",
    "fixtures",
    "scripts",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ]
}
